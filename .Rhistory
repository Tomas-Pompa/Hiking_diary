reticulate::repl_python()
fix_data <- read_parquet("fix_df_example.parquet")
# Code value of 2 to 0
fix_data$value[fix_data$value > 1] <- 0
#| fig-width: 15
#| fig-height: 10
fix_data %>%
filter(value > 0) %>%
ggplot(aes(x = pixels_x, y = pixels_y, col = Image)) +
geom_rect(xmin = 0, ymin = 0, xmax = n_pixels[1], ymax = n_pixels[2], col = "grey", fill = NA, linetype = "dashed") +
geom_point(alpha = 0.4, size = 2) +
facet_wrap(~ID) +
theme_bw() +
theme(aspect.ratio = n_pixels[2]/n_pixels[1],
panel.grid = element_blank()) +
lims(x = c(0, n_pixels[1]), y = c(0, n_pixels[2]))
#| fig-width: 15
#| fig-height: 10
